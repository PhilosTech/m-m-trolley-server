# --- PostgreSQL (local Docker: see ../docker-compose.yml) ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/trolley?schema=public"

JWT_SECRET="change-me-in-production"
ADMIN_ACCESS_CODE="ADMIN2026"
PARTICIPANT_ACCESS_CODE="PARTICIPANT2026"
PORT=4000
FRONTEND_ORIGIN="http://localhost:3000"

# Max JSON body size (location updates include base64 data URLs). Example: 32mb, 50mb
JSON_BODY_LIMIT="32mb"
# Max characters per photo URL string (default ~28 MB encoded)
# MAX_PHOTO_DATA_URL_CHARS="29360128"

# --- MinIO (S3-compatible) — for local photo uploads (API wiring comes next) ---
# API: http://localhost:9000  Console: http://localhost:9001  (minioadmin / minioadmin)
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="trolley-photos"
# Public base URL for browser-loaded images (MinIO path-style or your reverse proxy)
S3_PUBLIC_BASE_URL="http://localhost:9000/trolley-photos"