generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum LocationStatus {
  draft
  published
}

model Location {
  id              String         @id @default(cuid())
  title           String         @default("")
  googleMapsUrl   String?
  photoUrls       Json           @default("[]")
  description     String?
  status          LocationStatus @default(draft)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  slots           TimeSlot[]
}

model TimeSlot {
  id           String    @id @default(cuid())
  locationId   String
  location     Location  @relation(fields: [locationId], references: [id], onDelete: Cascade)
  startTime    DateTime
  endTime      DateTime
  capacity     Int
  bookings     Booking[]

  @@index([locationId])
}

model Booking {
  id              String   @id @default(cuid())
  timeSlotId      String
  timeSlot        TimeSlot @relation(fields: [timeSlotId], references: [id], onDelete: Cascade)
  participantName String
  seats           Int
  createdAt       DateTime @default(now())

  @@index([timeSlotId])
}

model BookingPolicyState {
  id                  Int    @id @default(1)
  isGlobalLocked      Boolean @default(false)
  lockedLocationIds   Json    @default("[]")
  mapPhotoUrl         String?
}

model MapLocationDraft {
  id             String   @id @default(cuid())
  positionNumber Int
  title          String   @default("")
  photoUrl       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([positionNumber])
  @@index([createdAt])
}
